;; ====================================================== TRANS: trn_batch =====
[Function: Export Ldr Batch]
    Variable : L : String
    Variable : c : String
    001 : Delete File : "trn_batch.tsv"
    010 : OPEN FILE : "trn_batch.tsv" : Text : Write : ASCII
    020 : WRITE FILE LINE : "guid"+@@LdrTab+"item"+@@LdrTab+"name"+@@LdrTab+"quantity"+@@LdrTab+"amount"+@@LdrTab+"godown"+@@LdrTab+"destination_godown"+@@LdrTab+"tracking_number"
    100 : WALK COLLECTION : Ldr_Batch
    110 :   SET : L : $$LdrT:$Guid + @@LdrTab + $$LdrT:$StockItemName
    111 :   SET : L : ##L + @@LdrTab + $$LdrT:$BatchName
    112 :   SET : L : ##L + @@LdrTab + $$LdrQ:$ActualQty
    113 :   SET : L : ##L + @@LdrTab + $$LdrA:$Amount
    114 :   SET : L : ##L + @@LdrTab + $$LdrT:$GodownName
    115 :   SET : L : ##L + @@LdrTab + $$LdrT:$DestinationGodownName
    116 :   SET : c : if ($$IsEmpty:$TrackingNumber or $$IsNotApplicable:$TrackingNumber) then "" else $TrackingNumber
    117 :   SET : L : ##L + @@LdrTab + $$LdrT:##c
    130 :   WRITE FILE LINE : ##L
    190 : END WALK
    199 : CLOSE TARGET FILE

;; ============================================================ Export ALL =====
[Function: Export Ldr ALL]
    10 : CALL : Export Ldr Group
    11 : CALL : Export Ldr Ledger
    12 : CALL : Export Ldr VoucherType
    13 : CALL : Export Ldr StockItem
    14 : CALL : Export Ldr Godown
    15 : CALL : Export Ldr CostCategory
    16 : CALL : Export Ldr CostCentre
    17 : CALL : Export Ldr Voucher
    18 : CALL : Export Ldr Accounting
    19 : CALL : Export Ldr Inventory
    20 : CALL : Export Ldr CostCentreTxn
    21 : CALL : Export Ldr Bill
    22 : CALL : Export Ldr Bank
    23 : CALL : Export Ldr Batch

;; ============================================================ COLLECTIONS ====
;; -- masters --
[Collection: Ldr_Group]
    Type : Group
[Collection: Ldr_Ledger]
    Type : Ledger
[Collection: Ldr_VchType]
    Type : VoucherType
[Collection: Ldr_StockItem]
    Type  : StockItem
    Fetch : GstDetails, PartNo
[Collection: Ldr_Godown]
    Type : Godown
[Collection: Ldr_CostCat]
    Type : CostCategory
[Collection: Ldr_CostCtr]
    Type : CostCentre

;; -- transaction root --
[Collection: Ldr_Vch]
    Type   : Voucher
    Fetch  : Narration, PartyLedgerName, PlaceOfSupply, Reference, ReferenceDate
    Filter : LdrActive

;; -- derived: ledger entries + their allocations --
[Collection: Ldr_Acc]
    Source Collection : Ldr_Vch
    Walk  : All Ledger Entries
    Fetch : Guid, LedgerName, Amount

[Collection: Ldr_CC]
    Source Collection : Ldr_Acc
    Walk  : Cost Centre Allocations
    Fetch : Guid, LedgerName, Name, Amount

[Collection: Ldr_Bill]
    Source Collection : Ldr_Acc
    Walk  : Bill Allocations
    Fetch : Guid, LedgerName, Name, Amount, BillType, BillCreditPeriod

[Collection: Ldr_Bank]
    Source Collection : Ldr_Acc
    Walk  : Bank Allocations
    Fetch : Guid, LedgerName, TransactionType, InstrumentDate, InstrumentNumber, BankName, Amount, BankersDate

;; -- derived: inventory entries + batches --
[Collection: Ldr_Inv]
    Source Collection : Ldr_Vch
    Walk  : All Inventory Entries
    Fetch : Guid, StockItemName, ActualQty, Rate, Amount, AddlAmount, Discount, GodownName, TrackingNumber, OrderNo, OrderDueDate

[Collection: Ldr_Batch]
    Source Collection : Ldr_Inv
    Walk  : Batch Allocations
    Fetch : Guid, StockItemName, BatchName, ActualQty, Amount, GodownName, DestinationGodownName, TrackingNumber
