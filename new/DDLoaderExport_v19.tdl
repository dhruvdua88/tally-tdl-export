;; ============================================================================
;; Sri Ganeshji : Sri Balaji : Sri Pitreshwarji : Sri Durgaji : Sri Venkateshwara
;; ============================================================================
;; DDLoaderExport  -  v19  (tally-database-loader-FORMAT export, pure TDL)
;;   Fork-family; original untouched.
;;
;; Emits the SAME tables/columns/format as dhananjay1405/tally-database-loader,
;; but entirely from TDL (no external Node puller). One .tsv per loader table.
;;
;; FORMAT (matches loader exactly - see docs/LOADER_SCHEMA.md):
;;   * TAB-delimited, one header row of loader column names, CRLF rows.
;;   * Per-column value transform by loader "type": text/logical/date/number/
;;     amount/quantity/rate -> replicated in functions Ldr T/L/D/N/A/Q/R below,
;;     character-for-character with the loader's src/tally.mts generator.
;;   * Empty-date sentinel = char 241 ("n-tilde"), loader's NULL marker.
;;   * Every child (derived) table repeats the parent voucher GUID as col 1.
;;   * Transaction collections filtered NOT cancelled / NOT optional.
;;
;; MENU: Gateway > DD Loader Export  (key L) -> submenu, one item per table +
;;   "Export ALL". Output files: mst_group.tsv, mst_ledger.tsv, ... trn_batch.tsv
;;
;; NOTE: uses WRITE FILE LINE (not the report engine) because byte-exact TAB +
;; n-tilde-sentinel output cannot be produced by the ASCII/CSV export engine.
;; For very large data use loader's HTTP puller (docs/METHODS_LARGE_DATA.md).
;; ============================================================================

;; ------------------------------------------------------------ Menu + submenu -
[#Menu: Gateway of Tally]
    Add : Key Item : Before : @@locQuit : DD Loader Export : L : Menu : DD Loader Menu

[Menu: DD Loader Menu]
    Add : Key Item : Export ALL (loader format) : X : Call : Export Ldr ALL
    Add : Key Item : mst_group        : G : Call : Export Ldr Group
    Add : Key Item : mst_ledger       : L : Call : Export Ldr Ledger
    Add : Key Item : mst_vouchertype  : V : Call : Export Ldr VoucherType
    Add : Key Item : mst_stock_item   : S : Call : Export Ldr StockItem
    Add : Key Item : mst_godown       : O : Call : Export Ldr Godown
    Add : Key Item : mst_cost_category: K : Call : Export Ldr CostCategory
    Add : Key Item : mst_cost_centre  : C : Call : Export Ldr CostCentre
    Add : Key Item : trn_voucher      : U : Call : Export Ldr Voucher
    Add : Key Item : trn_accounting   : A : Call : Export Ldr Accounting
    Add : Key Item : trn_inventory    : I : Call : Export Ldr Inventory
    Add : Key Item : trn_cost_centre  : E : Call : Export Ldr CostCentreTxn
    Add : Key Item : trn_bill         : B : Call : Export Ldr Bill
    Add : Key Item : trn_bank         : N : Call : Export Ldr Bank
    Add : Key Item : trn_batch        : T : Call : Export Ldr Batch

;; ------------------------------------------------------ format constants -----
[System: Formula]
    LdrTab   : $$StrByCharCode:9
    LdrCR    : $$StrByCharCode:13
    LdrLF    : $$StrByCharCode:10
    LdrNull  : $$StrByCharCode:241
    LdrActive: NOT $IsCancelled AND NOT $IsOptional

;; ------------------------------------------ type formatters (loader-exact) ---
;; text: strip TAB/CR/LF -> space (loader cleans embedded separators)
[Function: LdrT]
    Parameter : v : String
    Returns   : String
    Variable  : t : String
    10 : SET : t : $$StringFindAndReplace:##v:@@LdrTab:" "
    20 : SET : t : $$StringFindAndReplace:##t:@@LdrCR:" "
    30 : SET : t : $$StringFindAndReplace:##t:@@LdrLF:" "
    40 : RETURN : ##t

;; logical: 1/0
[Function: LdrL]
    Parameter : v : Logical
    Returns   : String
    10 : RETURN : if ##v then "1" else "0"

;; date: YYYY-MM-DD or n-tilde sentinel when empty
[Function: LdrD]
    Parameter : v : Date
    Returns   : String
    10 : RETURN : if $$IsEmpty:##v then @@LdrNull else $$PyrlYYYYMMDDFormat:##v:"-"

;; number: "0" when empty, else stringified with (-)->-
[Function: LdrN]
    Parameter : v : String
    Returns   : String
    10 : RETURN : if $$IsEmpty:##v then "0" else $$StringFindAndReplace:($$String:##v):"(-)":"-"

;; amount: sign-normalised via IsDebit, (-)->-
[Function: LdrA]
    Parameter : v : Amount
    Returns   : String
    10 : RETURN : $$StringFindAndReplace:(if $$IsDebit:##v then -$$NumValue:##v else $$NumValue:##v):"(-)":"-"

;; quantity: sign via IsInwards, TailUnits number, (-)->-
[Function: LdrQ]
    Parameter : v : Quantity
    Returns   : String
    10 : RETURN : $$StringFindAndReplace:(if $$IsInwards:##v then $$Number:$$String:##v:"TailUnits" else -$$Number:$$String:##v:"TailUnits"):"(-)":"-"

;; rate: 0 when empty else number
[Function: LdrR]
    Parameter : v : Rate
    Returns   : String
    10 : RETURN : if $$IsEmpty:##v then "0" else $$Number:##v

;; ======================================================= MASTER: mst_group ===
[Function: Export Ldr Group]
    Variable : L : String
    Variable : c : String
    001 : Delete File : "mst_group.tsv"
    010 : OPEN FILE : "mst_group.tsv" : Text : Write : ASCII
    020 : WRITE FILE LINE : "guid"+@@LdrTab+"name"+@@LdrTab+"parent"+@@LdrTab+"primary_group"+@@LdrTab+"is_revenue"+@@LdrTab+"is_deemedpositive"+@@LdrTab+"is_reserved"+@@LdrTab+"affects_gross_profit"+@@LdrTab+"sort_position"
    100 : WALK COLLECTION : Ldr_Group
    110 :   SET : L : $$LdrT:$Guid + @@LdrTab + $$LdrT:$Name
    111 :   SET : c : if $$IsEqual:$Parent:$$SysName:Primary then "" else $Parent
    112 :   SET : L : ##L + @@LdrTab + $$LdrT:##c
    113 :   SET : L : ##L + @@LdrTab + $$LdrT:$_PrimaryGroup
    114 :   SET : L : ##L + @@LdrTab + $$LdrL:$IsRevenue
    115 :   SET : L : ##L + @@LdrTab + $$LdrL:$IsDeemedPositive
    116 :   SET : L : ##L + @@LdrTab + $$LdrL:$IsReserved
    117 :   SET : L : ##L + @@LdrTab + $$LdrL:$AffectsGrossProfit
    118 :   SET : L : ##L + @@LdrTab + $$LdrN:$SortPosition
    130 :   WRITE FILE LINE : ##L
    190 : END WALK
    199 : CLOSE TARGET FILE

;; ====================================================== MASTER: mst_ledger ===
[Function: Export Ldr Ledger]
    Variable : L : String
    Variable : c : String
    001 : Delete File : "mst_ledger.tsv"
    010 : OPEN FILE : "mst_ledger.tsv" : Text : Write : ASCII
    020 : WRITE FILE LINE : "guid"+@@LdrTab+"name"+@@LdrTab+"parent"+@@LdrTab+"alias"+@@LdrTab+"description"+@@LdrTab+"notes"+@@LdrTab+"is_revenue"+@@LdrTab+"is_deemedpositive"+@@LdrTab+"opening_balance"+@@LdrTab+"closing_balance"+@@LdrTab+"mailing_name"+@@LdrTab+"mailing_address"+@@LdrTab+"mailing_state"+@@LdrTab+"mailing_country"+@@LdrTab+"mailing_pincode"+@@LdrTab+"email"+@@LdrTab+"mobile"+@@LdrTab+"it_pan"+@@LdrTab+"gstn"+@@LdrTab+"gst_registration_type"+@@LdrTab+"gst_supply_type"+@@LdrTab+"gst_duty_head"+@@LdrTab+"bank_account_holder"+@@LdrTab+"bank_account_number"+@@LdrTab+"bank_ifsc"+@@LdrTab+"bank_swift"+@@LdrTab+"bank_name"+@@LdrTab+"bank_branch"+@@LdrTab+"bill_credit_period"
    100 : WALK COLLECTION : Ldr_Ledger
    110 :   SET : L : $$LdrT:$Guid + @@LdrTab + $$LdrT:$Name
    111 :   SET : c : if $$IsEqual:$Parent:$$SysName:Primary then "" else $Parent
    112 :   SET : L : ##L + @@LdrTab + $$LdrT:##c
    113 :   SET : L : ##L + @@LdrTab + $$LdrT:$OnlyAlias
    114 :   SET : L : ##L + @@LdrTab + $$LdrT:$Description
    115 :   SET : L : ##L + @@LdrTab + $$LdrT:$Narration
    116 :   SET : L : ##L + @@LdrTab + $$LdrL:$IsRevenue
    117 :   SET : L : ##L + @@LdrTab + $$LdrL:$IsDeemedPositive
    118 :   SET : L : ##L + @@LdrTab + $$LdrA:$OpeningBalance
    119 :   SET : L : ##L + @@LdrTab + $$LdrA:$ClosingBalance
    120 :   SET : L : ##L + @@LdrTab + $$LdrT:$MailingName
    121 :   SET : c : if $$IsEmpty:$Address then "" else $$FullList:Address:$Address
    122 :   SET : L : ##L + @@LdrTab + $$LdrT:##c
    123 :   SET : L : ##L + @@LdrTab + $$LdrT:$LedStateName
    124 :   SET : L : ##L + @@LdrTab + $$LdrT:$CountryName
    125 :   SET : L : ##L + @@LdrTab + $$LdrT:$PinCode
    126 :   SET : L : ##L + @@LdrTab + $$LdrT:$Email
    127 :   SET : c : if NOT $$IsEmpty:$LedgerMobile then $$Sprintf:"%s %s":$LedgerCountryISDCode:$LedgerMobile else ""
    128 :   SET : L : ##L + @@LdrTab + $$LdrT:##c
    129 :   SET : L : ##L + @@LdrTab + $$LdrT:$IncomeTaxNumber
    130 :   SET : c : if $$IsEmpty:$PartyGSTIN then $LedGSTRegDetails[Last].GSTIN else $PartyGSTIN
    131 :   SET : L : ##L + @@LdrTab + $$LdrT:##c
    132 :   SET : c : if $$IsEmpty:$Gstregistrationtype then $LedGSTRegDetails[Last].Gstregistrationtype else $Gstregistrationtype
    133 :   SET : L : ##L + @@LdrTab + $$LdrT:##c
    134 :   SET : L : ##L + @@LdrTab + $$LdrT:$Gsttypeofsupply
    135 :   SET : L : ##L + @@LdrTab + $$LdrT:$Gstdutyhead
    136 :   SET : L : ##L + @@LdrTab + $$LdrT:$Bankaccholdername
    137 :   SET : L : ##L + @@LdrTab + $$LdrT:$BankDetails
    138 :   SET : L : ##L + @@LdrTab + $$LdrT:$Ifscode
    139 :   SET : L : ##L + @@LdrTab + $$LdrT:$Swiftcode
    140 :   SET : L : ##L + @@LdrTab + $$LdrT:$Bankingconfigbank
    141 :   SET : L : ##L + @@LdrTab + $$LdrT:$BankBranchname
    142 :   SET : c : $$Number:$BillCreditPeriod
    143 :   SET : L : ##L + @@LdrTab + $$String:##c
    150 :   WRITE FILE LINE : ##L
    190 : END WALK
    199 : CLOSE TARGET FILE

