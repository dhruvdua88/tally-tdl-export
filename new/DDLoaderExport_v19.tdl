;; ==================================================== TRANS: trn_voucher =====
[Function: Export Ldr Voucher]
    Variable : L : String
    Variable : c : String
    001 : Delete File : "trn_voucher.tsv"
    010 : OPEN FILE : "trn_voucher.tsv" : Text : Write : ASCII
    020 : WRITE FILE LINE : "guid"+@@LdrTab+"date"+@@LdrTab+"voucher_type"+@@LdrTab+"voucher_number"+@@LdrTab+"reference_number"+@@LdrTab+"reference_date"+@@LdrTab+"narration"+@@LdrTab+"party_name"+@@LdrTab+"place_of_supply"+@@LdrTab+"is_invoice"+@@LdrTab+"is_accounting_voucher"+@@LdrTab+"is_inventory_voucher"+@@LdrTab+"is_order_voucher"
    100 : WALK COLLECTION : Ldr_Vch
    110 :   SET : L : $$LdrT:$Guid + @@LdrTab + $$LdrD:$Date
    111 :   SET : L : ##L + @@LdrTab + $$LdrT:$VoucherTypeName
    112 :   SET : L : ##L + @@LdrTab + $$LdrT:$VoucherNumber
    113 :   SET : L : ##L + @@LdrTab + $$LdrT:$Reference
    114 :   SET : L : ##L + @@LdrTab + $$LdrD:$ReferenceDate
    115 :   SET : L : ##L + @@LdrTab + $$LdrT:$Narration
    116 :   SET : L : ##L + @@LdrTab + $$LdrT:$PartyLedgerName
    117 :   SET : L : ##L + @@LdrTab + $$LdrT:$PlaceOfSupply
    118 :   SET : L : ##L + @@LdrTab + $$LdrL:$IsInvoice
    119 :   SET : c : if $$IsAccountingVch:$VoucherTypeName then "1" else "0"
    120 :   SET : L : ##L + @@LdrTab + ##c
    121 :   SET : c : if $$IsInventoryVch:$VoucherTypeName then "1" else "0"
    122 :   SET : L : ##L + @@LdrTab + ##c
    123 :   SET : c : if $$IsOrderVch:$VoucherTypeName then "1" else "0"
    124 :   SET : L : ##L + @@LdrTab + ##c
    130 :   WRITE FILE LINE : ##L
    190 : END WALK
    199 : CLOSE TARGET FILE

;; ================================================= TRANS: trn_accounting =====
[Function: Export Ldr Accounting]
    Variable : L : String
    Variable : c : String
    001 : Delete File : "trn_accounting.tsv"
    010 : OPEN FILE : "trn_accounting.tsv" : Text : Write : ASCII
    020 : WRITE FILE LINE : "guid"+@@LdrTab+"ledger"+@@LdrTab+"amount"+@@LdrTab+"amount_forex"+@@LdrTab+"currency"
    100 : WALK COLLECTION : Ldr_Acc
    110 :   SET : L : $$LdrT:$Guid + @@LdrTab + $$LdrT:$LedgerName
    111 :   SET : L : ##L + @@LdrTab + $$LdrA:$Amount
    112 :   SET : c : if $$IsEmpty:$$ForexValue:$Amount then 0 else $$StringFindAndReplace:(if $$IsDebit:$Amount then -$$ForexValue:$Amount else $$ForexValue:$Amount):"(-)":"-"
    113 :   SET : L : ##L + @@LdrTab + $$String:##c
    114 :   SET : c : $$Currency:$Amount
    115 :   SET : L : ##L + @@LdrTab + $$LdrT:##c
    130 :   WRITE FILE LINE : ##L
    190 : END WALK
    199 : CLOSE TARGET FILE

