;; =================================================== MASTER: mst_stock_item ===
[Function: Export Ldr StockItem]
    Variable : L : String
    Variable : c : String
    001 : Delete File : "mst_stock_item.tsv"
    010 : OPEN FILE : "mst_stock_item.tsv" : Text : Write : ASCII
    020 : WRITE FILE LINE : "guid"+@@LdrTab+"name"+@@LdrTab+"parent"+@@LdrTab+"category"+@@LdrTab+"alias"+@@LdrTab+"description"+@@LdrTab+"notes"+@@LdrTab+"part_number"+@@LdrTab+"uom"+@@LdrTab+"alternate_uom"+@@LdrTab+"conversion"+@@LdrTab+"opening_balance"+@@LdrTab+"opening_rate"+@@LdrTab+"opening_value"+@@LdrTab+"closing_balance"+@@LdrTab+"closing_rate"+@@LdrTab+"closing_value"+@@LdrTab+"costing_method"+@@LdrTab+"gst_type_of_supply"+@@LdrTab+"gst_hsn_code"+@@LdrTab+"gst_hsn_description"+@@LdrTab+"gst_rate"+@@LdrTab+"gst_taxability"
    100 : WALK COLLECTION : Ldr_StockItem
    110 :   SET : L : $$LdrT:$Guid + @@LdrTab + $$LdrT:$Name
    111 :   SET : c : if $$IsEqual:$Parent:$$SysName:Primary then "" else $Parent
    112 :   SET : L : ##L + @@LdrTab + $$LdrT:##c
    113 :   SET : c : if $$IsEqual:$Category:$$SysName:NotApplicable then "" else $Category
    114 :   SET : L : ##L + @@LdrTab + $$LdrT:##c
    115 :   SET : L : ##L + @@LdrTab + $$LdrT:$OnlyAlias
    116 :   SET : L : ##L + @@LdrTab + $$LdrT:$Description
    117 :   SET : L : ##L + @@LdrTab + $$LdrT:$Narration
    118 :   SET : L : ##L + @@LdrTab + $$LdrT:$PartNo
    119 :   SET : c : if $$IsEqual:$BaseUnits:$$SysName:NotApplicable then "" else $BaseUnits
    120 :   SET : L : ##L + @@LdrTab + $$LdrT:##c
    121 :   SET : c : if $$IsEqual:$AdditionalUnits:$$SysName:NotApplicable then "" else $AdditionalUnits
    122 :   SET : L : ##L + @@LdrTab + $$LdrT:##c
    123 :   SET : L : ##L + @@LdrTab + $$LdrN:$Conversion
    124 :   SET : L : ##L + @@LdrTab + $$LdrQ:$OpeningBalance
    125 :   SET : L : ##L + @@LdrTab + $$LdrR:$OpeningRate
    126 :   SET : L : ##L + @@LdrTab + $$LdrA:$OpeningValue
    127 :   SET : L : ##L + @@LdrTab + $$LdrQ:$ClosingBalance
    128 :   SET : L : ##L + @@LdrTab + $$LdrR:$ClosingRate
    129 :   SET : L : ##L + @@LdrTab + $$LdrA:$ClosingValue
    130 :   SET : L : ##L + @@LdrTab + $$LdrT:$CostingMethod
    131 :   SET : L : ##L + @@LdrTab + $$LdrT:$GSTMSTTypeofSupply
    132 :   SET : L : ##L + @@LdrTab + $$LdrT:$InfGSTHSNCode
    133 :   SET : L : ##L + @@LdrTab + $$LdrT:$InfGSTHSNDescription
    134 :   SET : L : ##L + @@LdrTab + $$LdrN:$InfGSTIGSTRate
    135 :   SET : L : ##L + @@LdrTab + $$LdrT:$InfGSTTaxablility
    150 :   WRITE FILE LINE : ##L
    190 : END WALK
    199 : CLOSE TARGET FILE

