    115 :   SET : L : ##L + @@LdrTab + $$LdrN:$Discount
    116 :   SET : L : ##L + @@LdrTab + $$LdrT:$GodownName
    117 :   SET : c : if ($$IsEmpty:$TrackingNumber or $$IsNotApplicable:$TrackingNumber) then "" else $TrackingNumber
